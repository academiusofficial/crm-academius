rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive ID Verification Guard
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for master collection of prospects
    match /leads/{leadId} {
      allow read, get, list: if true;
      allow create, update: if isValidId(leadId)
        && request.resource.data.id is string
        && request.resource.data.namaLengkap is string
        && request.resource.data.namaLengkap.size() <= 150
        && request.resource.data.nomorWhatsApp is string
        && request.resource.data.nomorWhatsApp.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 100;
      allow delete: if true;
    }

    // Rules for counselor tasks and callbacks
    match /tasks/{taskId} {
      allow read, get, list: if true;
      allow create, update: if isValidId(taskId)
        && request.resource.data.id is string
        && request.resource.data.todo is string
        && request.resource.data.todo.size() <= 500
        && request.resource.data.pic is string
        && request.resource.data.pic.size() <= 100;
      allow delete: if true;
    }

    // Rules for auditable activity logs
    match /logs/{logId} {
      allow read, get, list: if true;
      allow create, update: if isValidId(logId)
        && request.resource.data.id is string
        && request.resource.data.aktivitas is string
        && request.resource.data.aktivitas.size() <= 1000
        && request.resource.data.user is string
        && request.resource.data.user.size() <= 100;
      allow delete: if true;
    }

    // Rules for communication chats history
    match /chats/{chatId} {
      allow read, get, list: if true;
      allow create, update: if isValidId(chatId)
        && request.resource.data.id is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && request.resource.data.sender is string
        && (request.resource.data.sender == 'counselor' || request.resource.data.sender == 'lead');
      allow delete: if true;
    }
  }
}
